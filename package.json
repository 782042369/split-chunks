{
  "name": "@xiaowaibuzheng/rolldown-vite-split-chunks",
  "version": "0.0.21",
  "description": "rolldown-vite split chunks plugin",
  "main": "es/index.mjs",
  "module": "es/index.mjs",
  "types": "es/index.d.mts",
  "type": "module",
  "scripts": {
    "watch": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version && npm publish && git push --tags",
    "prepare": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "files": [
    "es",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/782042369/split-chunks.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "keywords": [
    "vite",
    "rolldown",
    "split-chunks",
    "plugin"
  ],
  "author": "waibuzheng",
  "license": "ISC",
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "standard-version": "^9.5.0",
    "tsdown": "^0.21.10",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
